{
  "name": "eo-translatorjs",
  "version": "3.1.2",
  "description": "A simple javascript library for translating web content.",
  "directories": {
    "doc": "docs"
  },
  "author": "EOussama",
  "license": "MIT",
  "homepage": "https://eoussama.github.io/eo-translatorjs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EOussama/eo-translatorjs.git"
  },
  "bugs": {
    "url": "https://github.com/EOussama/eo-translatorjs/issues"
  },
  "keywords": [
    "translate",
    "javascript-library",
    "text-translation",
    "node-package"
  ],
  "main": "./dist/eo-translatorjs.js",
  "types": "types/eo-translatorjs.d.ts",
  "scripts": {
    "build": "gulp",
    "test": "jest",
    "lint": "dx lint",
    "lint:fix": "dx lint --fix",
    "clean": "rm -rf ./dist/",
    "demos": "cp ./dist/eo-translatorjs.min.js ./demos/assets/js/",
    "prod": "pnpm run clean && pnpm run build && pnpm run demos"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eoussama/dx": "^0.0.4",
    "gulp": "^5.0.1",
    "gulp-babel": "^8.0.0",
    "gulp-beautify": "^3.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-uglify": "^3.0.2",
    "jest": "^29.7.0",
    "jsdom": "^26.0.0"
  }
}
